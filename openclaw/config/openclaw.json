{
    "gateway": {
        "controlUi": {
            "dangerouslyAllowHostHeaderOriginFallback": true
        }
    },
    "models": {
        "providers": {
            "rustassistant": {
                "baseUrl": "http://ra-app:3500/v1",
                "apiKey": "${OPENAI_API_KEY}",
                "api": "openai-completions",
                "models": [
                    {
                        "id": "rustassistant",
                        "name": "RustAssistant (auto-route)",
                        "api": "openai-completions",
                        "reasoning": false,
                        "input": ["text"],
                        "cost": {
                            "input": 0,
                            "output": 0,
                            "cacheRead": 0,
                            "cacheWrite": 0
                        },
                        "contextWindow": 131072,
                        "maxTokens": 32768
                    },
                    {
                        "id": "auto",
                        "name": "RustAssistant Auto",
                        "api": "openai-completions",
                        "reasoning": false,
                        "input": ["text"],
                        "cost": {
                            "input": 0,
                            "output": 0,
                            "cacheRead": 0,
                            "cacheWrite": 0
                        },
                        "contextWindow": 131072,
                        "maxTokens": 32768
                    },
                    {
                        "id": "local",
                        "name": "RustAssistant Local (Ollama)",
                        "api": "openai-completions",
                        "reasoning": false,
                        "input": ["text"],
                        "cost": {
                            "input": 0,
                            "output": 0,
                            "cacheRead": 0,
                            "cacheWrite": 0
                        },
                        "contextWindow": 16384,
                        "maxTokens": 8192
                    },
                    {
                        "id": "remote",
                        "name": "RustAssistant Remote (Grok)",
                        "api": "openai-completions",
                        "reasoning": true,
                        "input": ["text"],
                        "cost": {
                            "input": 0,
                            "output": 0,
                            "cacheRead": 0,
                            "cacheWrite": 0
                        },
                        "contextWindow": 131072,
                        "maxTokens": 32768
                    }
                ]
            }
        }
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "rustassistant/rustassistant"
            },
            "models": {
                "rustassistant/rustassistant": {}
            },
            "compaction": {
                "mode": "safeguard"
            },
            "maxConcurrent": 4,
            "subagents": {
                "maxConcurrent": 8
            }
        }
    },
    "messages": {
        "ackReactionScope": "group-mentions"
    },
    "commands": {
        "native": "auto",
        "nativeSkills": "auto",
        "restart": true,
        "ownerDisplay": "raw"
    },
    "channels": {
        "discord": {
            "enabled": true,
            "groupPolicy": "allowlist",
            "streaming": "off"
        }
    }
}
