# ============================================================================
# RustAssistant .env Configuration
# ============================================================================
# Copy this file to `.env` (in the same folder as docker-compose.yml)
# Then run: docker compose up -d

# ────────────────────────────────────────────────────────────────────────────
# REQUIRED SECRETS (CHANGE THESE!)
# ────────────────────────────────────────────────────────────────────────────
XAI_API_KEY=sk-your-xai-api-key-here
GITHUB_TOKEN=ghp_your_personal_access_token_here   # read scope: repo, read:user

# Postgres + Redis passwords
RA_POSTGRES_PASSWORD=SuperSecretPassword123!ChangeMeNow
RA_REDIS_PASSWORD=SuperSecretPassword123!ChangeMeNow

# Proxy API key — shared by OpenClaw, futures app, and any other consumers.
# Both vars below must be the same value.
# Generate with: openssl rand -hex 32
RA_PROXY_API_KEYS=generate-a-strong-random-key-here
RA_API_KEY=generate-a-strong-random-key-here

RA_BASE_URL=http://ra-app:3500     # internal Docker network — used by OpenClaw
RA_REPO_ID=rustassistant           # optional: inject repo RAG context into every call

# Tailscale — all ports bind to this IP only, never the public interface.
# Find yours: ip addr show tailscale0 | grep 'inet ' | awk '{print $2}' | cut -d/ -f1
TAILSCALE_IP=100.x.x.x

# ────────────────────────────────────────────────────────────────────────────
# OpenClaw
# ────────────────────────────────────────────────────────────────────────────
OPENCLAW_IMAGE=openclaw:local              # swap to registry tag if pulling pre-built
OPENCLAW_GATEWAY_TOKEN=generate-a-strong-random-secret-here
OPENCLAW_CONFIG_DIR=./openclaw/config      # drop agents.yml here before first start
OPENCLAW_WORKSPACE_DIR=./openclaw/workspace  # session notes + summaries land here
TZ=America/Toronto

# Discord bot
# Create at https://discord.com/developers → OAuth2 → Bot
# Required intents: GUILDS, GUILD_MESSAGES, MESSAGE_CONTENT
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# GitHub — OpenClaw uses the same GITHUB_TOKEN above (repo read scope)
GITHUB_USERNAME=nuniesmith
GITHUB_ORG=                                # blank = personal repos only

# ────────────────────────────────────────────────────────────────────────────
# Server & Logging
# ────────────────────────────────────────────────────────────────────────────
PORT=3500
HOST=0.0.0.0
RUST_LOG=info,rustassistant=debug

# ────────────────────────────────────────────────────────────────────────────
# AI Providers & Models
# ────────────────────────────────────────────────────────────────────────────
XAI_BASE_URL=https://api.x.ai/v1
REMOTE_MODEL=grok-4-1-fast-reasoning
XAI_MODEL=grok-4-1-fast-reasoning
XAI_MAX_TOKENS=4096
XAI_TEMPERATURE=0.3

# Local Ollama (Docker internal hostname)
OLLAMA_BASE_URL=http://ra-ollama:11434
LOCAL_MODEL=qwen2.5-coder:7b
FORCE_REMOTE_MODEL=false

# ────────────────────────────────────────────────────────────────────────────
# GitHub Integration
# ────────────────────────────────────────────────────────────────────────────
GITHUB_OWNER=nuniesmith
GITHUB_BASE_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=                     # set if using push webhook → ra-app

# ────────────────────────────────────────────────────────────────────────────
# Paths & Storage
# ────────────────────────────────────────────────────────────────────────────
REPOS_BASE_PATH=/home/jordan/github/

# Inside-container paths (do NOT change these)
DATABASE_URL=postgres://rustassistant:${RA_POSTGRES_PASSWORD}@ra-postgres:5432/rustassistant
REPOS_DIR=/app/repos
DATA_DIR=/app/data

# ────────────────────────────────────────────────────────────────────────────
# Redis & Caching
# ────────────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_PREFIX=rustassistant

# ────────────────────────────────────────────────────────────────────────────
# Background Services & Features
# ────────────────────────────────────────────────────────────────────────────
REPO_SYNC_INTERVAL_SECS=300
AUTO_SCAN_ENABLED=true
AUTO_SCAN_INTERVAL=60
AUTO_SCAN_MAX_CONCURRENT=2

# ────────────────────────────────────────────────────────────────────────────
# LLM Budget & Cost Control (optional)
# ────────────────────────────────────────────────────────────────────────────
DAILY_BUDGET_USD=5.00
WARN_AT_PERCENT=80
BLOCK_ON_EXCEED=true

# ────────────────────────────────────────────────────────────────────────────
# Analysis Settings (optional)
# ────────────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=1000000
INCLUDE_TESTS=true
PARALLEL_JOBS=4

# ────────────────────────────────────────────────────────────────────────────
# Legacy / unused (safe to delete)
# ────────────────────────────────────────────────────────────────────────────
# VECTOR_DIM=1536
# CHUNK_SIZE=512
# WORKSPACE_DIR=data/workspaces
# ENABLE_WEB_UI=false          # WebUI removed — API-only mode
# ENABLE_AUTO_ANALYSIS=false
# ENABLE_GITHUB_SYNC=false
